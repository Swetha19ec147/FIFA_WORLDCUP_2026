# ─────────────────────────────────────────────────────────────────────────────
# Visionary FIFA — Environment Variables
# Copy this file to .env.local and fill in real values before running locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────────────
# Public URL where the site is deployed (no trailing slash).
# Used for canonical URLs, Open Graph tags, sitemap, and structured data.
NEXT_PUBLIC_SITE_URL=https://visionaryfifa.com

# ── SEO ───────────────────────────────────────────────────────────────────────
# Google Search Console ownership-verification meta-tag value.
# Get it from: Search Console → Settings → Ownership verification → HTML tag.
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND TEAM — add your own variables below as you integrate live data:
#
# DATABASE_URL=           (PostgreSQL / MySQL / etc.)
# LIVE_SCORES_API_KEY=    (API-Football, SportMonks, or similar)
# LIVE_SCORES_BASE_URL=
# NEWS_CMS_API_KEY=       (Contentful, Sanity, Strapi, etc.)
# REVALIDATION_SECRET=    (shared secret for on-demand ISR revalidation)
# ─────────────────────────────────────────────────────────────────────────────
